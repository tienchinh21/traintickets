generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserType {
  CUSTOMER
  STAFF
  SYSTEM
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum RoleStatus {
  ACTIVE
  INACTIVE
}

enum PermissionStatus {
  ACTIVE
  INACTIVE
}

enum StationStatus {
  ACTIVE
  INACTIVE
}

enum RouteStatus {
  ACTIVE
  INACTIVE
}

enum TrainStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

enum SeatTypeStatus {
  ACTIVE
  INACTIVE
}

enum CarriageStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

enum SeatStatus {
  ACTIVE
  BROKEN
  INACTIVE
}

model User {
  id           String     @id @default(uuid()) @db.Char(36)
  email        String?    @unique @db.VarChar(255)
  phone        String?    @unique @db.VarChar(30)
  passwordHash String?    @map("password_hash") @db.VarChar(255)
  fullName     String     @map("full_name") @db.VarChar(255)
  userType     UserType   @map("user_type")
  status       UserStatus
  lastLoginAt  DateTime?  @map("last_login_at") @db.DateTime(3)
  createdAt    DateTime   @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt    DateTime?  @map("deleted_at") @db.DateTime(3)

  roles         UserRole[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]     @relation("ActorAuditLogs")

  @@index([userType])
  @@index([status])
  @@map("users")
}

model Role {
  id          BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  code        String     @unique @db.VarChar(50)
  name        String     @db.VarChar(100)
  description String?    @db.VarChar(500)
  status      RoleStatus
  createdAt   DateTime   @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.DateTime(3)

  users       UserRole[]
  permissions RolePermission[]

  @@index([status])
  @@map("roles")
}

model Permission {
  id          BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  code        String           @unique @db.VarChar(100)
  name        String           @db.VarChar(150)
  description String?          @db.VarChar(500)
  module      String           @db.VarChar(100)
  action      String           @db.VarChar(50)
  method      String?          @db.VarChar(10)
  path        String?          @db.VarChar(255)
  status      PermissionStatus
  createdAt   DateTime         @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.DateTime(3)

  roles RolePermission[]

  @@index([module])
  @@index([action])
  @@index([method, path])
  @@index([status])
  @@map("permissions")
}

model UserRole {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId    String   @map("user_id") @db.Char(36)
  roleId    BigInt   @map("role_id") @db.UnsignedBigInt
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  roleId       BigInt   @map("role_id") @db.UnsignedBigInt
  permissionId BigInt   @map("permission_id") @db.UnsignedBigInt
  createdAt    DateTime @default(now()) @map("created_at") @db.DateTime(3)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId     String    @map("user_id") @db.Char(36)
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  deviceName String?   @map("device_name") @db.VarChar(255)
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  userAgent  String?   @map("user_agent") @db.VarChar(1000)
  expiresAt  DateTime  @map("expires_at") @db.DateTime(3)
  revokedAt  DateTime? @map("revoked_at") @db.DateTime(3)
  createdAt  DateTime  @default(now()) @map("created_at") @db.DateTime(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  actorUserId String?  @map("actor_user_id") @db.Char(36)
  action      String   @db.VarChar(100)
  entityType  String   @map("entity_type") @db.VarChar(100)
  entityId    String?  @map("entity_id") @db.VarChar(100)
  beforeJson  Json?    @map("before_json")
  afterJson   Json?    @map("after_json")
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  userAgent   String?  @map("user_agent") @db.VarChar(1000)
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(3)

  actor User? @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Station {
  id        String        @id @default(uuid()) @db.Char(36)
  code      String        @unique @db.VarChar(20)
  name      String        @db.VarChar(255)
  slug      String        @unique @db.VarChar(255)
  city      String?       @db.VarChar(100)
  address   String?       @db.VarChar(500)
  latitude  Decimal?      @db.Decimal(10, 7)
  longitude Decimal?      @db.Decimal(10, 7)
  timezone  String        @default("Asia/Ho_Chi_Minh") @db.VarChar(50)
  status    StationStatus
  createdAt DateTime      @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime      @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt DateTime?     @map("deleted_at") @db.DateTime(3)

  routeStops RouteStop[]

  @@index([name])
  @@index([city])
  @@index([status])
  @@map("stations")
}

model Route {
  id          String      @id @default(uuid()) @db.Char(36)
  code        String      @unique @db.VarChar(30)
  name        String      @db.VarChar(255)
  description String?     @db.VarChar(1000)
  status      RouteStatus
  createdAt   DateTime    @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt   DateTime?   @map("deleted_at") @db.DateTime(3)

  stops RouteStop[]

  @@index([status])
  @@map("routes")
}

model RouteStop {
  id                            String   @id @default(uuid()) @db.Char(36)
  routeId                       String   @map("route_id") @db.Char(36)
  stationId                     String   @map("station_id") @db.Char(36)
  stopOrder                     Int      @map("stop_order") @db.UnsignedInt
  distanceFromStartKm           Decimal  @map("distance_from_start_km") @db.Decimal(8, 2)
  defaultArrivalOffsetMinutes   Int?     @map("default_arrival_offset_minutes") @db.UnsignedInt
  defaultDepartureOffsetMinutes Int?     @map("default_departure_offset_minutes") @db.UnsignedInt
  createdAt                     DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt                     DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  route   Route   @relation(fields: [routeId], references: [id])
  station Station @relation(fields: [stationId], references: [id])

  @@unique([routeId, stopOrder])
  @@unique([routeId, stationId])
  @@index([stationId])
  @@map("route_stops")
}

model Train {
  id          String      @id @default(uuid()) @db.Char(36)
  code        String      @unique @db.VarChar(30)
  name        String      @db.VarChar(255)
  description String?     @db.VarChar(1000)
  status      TrainStatus
  createdAt   DateTime    @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt   DateTime?   @map("deleted_at") @db.DateTime(3)

  carriages Carriage[]

  @@index([status])
  @@map("trains")
}

model SeatType {
  id             String         @id @default(uuid()) @db.Char(36)
  code           String         @unique @db.VarChar(30)
  name           String         @db.VarChar(100)
  description    String?        @db.VarChar(500)
  baseMultiplier Decimal        @map("base_multiplier") @db.Decimal(5, 2)
  status         SeatTypeStatus
  createdAt      DateTime       @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.DateTime(3)

  seats Seat[]

  @@index([status])
  @@map("seat_types")
}

model Carriage {
  id              String         @id @default(uuid()) @db.Char(36)
  trainId         String         @map("train_id") @db.Char(36)
  carriageNumber  Int            @map("carriage_number") @db.UnsignedInt
  name            String         @db.VarChar(100)
  carriageType    String         @map("carriage_type") @db.VarChar(50)
  seatMapLayout   Json?          @map("seat_map_layout")
  status          CarriageStatus
  createdAt       DateTime       @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt       DateTime?      @map("deleted_at") @db.DateTime(3)

  train Train @relation(fields: [trainId], references: [id])
  seats Seat[]

  @@unique([trainId, carriageNumber])
  @@index([trainId])
  @@index([status])
  @@map("carriages")
}

model Seat {
  id           String     @id @default(uuid()) @db.Char(36)
  carriageId   String     @map("carriage_id") @db.Char(36)
  seatTypeId   String     @map("seat_type_id") @db.Char(36)
  seatNumber   String     @map("seat_number") @db.VarChar(20)
  rowNumber    Int?       @map("row_number") @db.UnsignedInt
  columnNumber Int?       @map("column_number") @db.UnsignedInt
  floorNumber  Int?       @map("floor_number") @db.UnsignedInt
  status       SeatStatus
  createdAt    DateTime   @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt    DateTime?  @map("deleted_at") @db.DateTime(3)

  carriage Carriage @relation(fields: [carriageId], references: [id])
  seatType SeatType @relation(fields: [seatTypeId], references: [id])

  @@unique([carriageId, seatNumber])
  @@index([seatTypeId])
  @@index([status])
  @@map("seats")
}
